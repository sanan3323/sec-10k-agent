# ─── SEC EDGAR ───────────────────────────────────────────────────────────────
# REQUIRED. SEC requires a User-Agent header with a contact email on every
# request. Filings are public; this is just for them to reach you if you cause
# load issues. Format: "Your Name your@email.com"
# Hard cap: 10 requests/sec. Our client throttles to 5/sec by default.
SEC_USER_AGENT="Your Name you@example.com"

# ─── LLMs ────────────────────────────────────────────────────────────────────
# xAI Grok is the generator. The OpenAI SDK is used with a custom base_url —
# this is a deliberate choice so swapping providers is one config change.
XAI_API_KEY=
XAI_BASE_URL="https://api.x.ai/v1"
XAI_MODEL="grok-4"

# Gemini is the LLM-as-judge for Phase 4 evals. Different model family from
# the generator to avoid self-judging bias. Free tier is generous enough for
# our eval workloads.
GEMINI_API_KEY=
GEMINI_JUDGE_MODEL="gemini-2.5-flash"

# Optional Ollama fallback for the judge if Gemini quotas tighten.
# Leave OLLAMA_BASE_URL blank to disable.
# OLLAMA_BASE_URL="http://localhost:11434"
# OLLAMA_JUDGE_MODEL="llama3.1:8b"

# ─── Storage (Phase 2+) ──────────────────────────────────────────────────────
# Single Postgres DSN — vectors and metadata in one DB. See ADR-001.
POSTGRES_DSN="postgresql://postgres:postgres@localhost:5432/sec10k"

# ─── Observability (Phase 1+, recommended from day one) ──────────────────────
# Run Langfuse locally with docker-compose. Free, self-hosted.
# First-time setup: launch the stack, visit http://localhost:3000, create a
# project in the UI, and paste the keys it gives you here.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST="http://localhost:3000"

# ─── Cache (Phase 7) ─────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379/0"

# ─── App config ──────────────────────────────────────────────────────────────
LOG_LEVEL="INFO"
ENV="dev"                            # dev | staging | prod
COST_ALERT_USD_PER_DAY="5.0"         # hard guardrail; agent refuses LLM calls above this
