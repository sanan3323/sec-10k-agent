# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.hypothesis/

# ─── Virtual environments ────────────────────────────────────────────────────
.venv/
venv/
env/
.python-version

# ─── Environment / secrets ───────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ─── Data (gitignored — too large, fetched via scripts) ──────────────────────
data/raw/**
data/processed/**
!data/raw/.gitkeep
!data/processed/.gitkeep
# Eval set IS committed — it's the source of truth for benchmarks
!data/eval/**

# ─── Models / caches ─────────────────────────────────────────────────────────
.cache/
models/
*.bin
*.safetensors

# ─── Notebooks ───────────────────────────────────────────────────────────────
.ipynb_checkpoints/
notebooks/scratch/

# ─── IDE ─────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# ─── Logs / runtime ──────────────────────────────────────────────────────────
*.log
logs/
.langfuse/
qdrant_storage/
